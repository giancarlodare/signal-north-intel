# Supabase project URL and the ANON / publishable key (NOT the service_role key).
# The anon key is safe to expose to the browser BECAUSE Row-Level Security
# (migrations/2026-07-09_signals_rls_review.sql) restricts all access to
# authenticated sessions. Never put SUPABASE_SERVICE_ROLE_KEY in this app.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY
